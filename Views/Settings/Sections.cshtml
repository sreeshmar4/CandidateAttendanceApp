@model CandidateAttendanceApp.ViewModels.PaginatedList<CandidateAttendanceApp.Models.Section>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Courses";
}

<section class="page-title-row reveal">
    <h2 class="mb-2">Manage Courses</h2>
    <p class="text-muted mb-0">Create and manage course names and fees for user organization.</p>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="panel-card reveal">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Add New Course</h5>
    </div>

    <form asp-action="CreateSection" method="post" class="row g-3 mb-4 pb-4 border-bottom">
        <div class="col-md-5">
            <label for="name" class="form-label">Course Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Enter course name" required />
        </div>
        <div class="col-md-3">
            <label for="fee" class="form-label">Fee</label>
            <input type="number" class="form-control" id="fee" name="fee" min="0" step="0.01" placeholder="Enter fee" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-plus-circle"></i> Add Course
            </button>
        </div>
    </form>

    <h5 class="mb-3">Existing Courses</h5>

    @{
        ViewData["CurrentPage"] = Model.CurrentPage;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["TotalRecords"] = Model.TotalRecords;
        ViewData["PaginationAction"] = "Sections";
        ViewData["PaginationController"] = "Settings";
        ViewData["PaginationRouteValues"] = new Dictionary<string, string?>();
    }
    
    @if (Model.Items.Any())
    {
        <div class="table-shell">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Course Name</th>
                        <th>Fee</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = (Model.CurrentPage - 1) * Model.PageSize + 1;
                    }
                    @foreach (var course in Model.Items)
                    {
                        var updateFormId = $"update-course-{course.Id}";
                        <tr>
                            <td>@i</td>
                            <td>
                                <input type="text"
                                       class="form-control form-control-sm"
                                       name="name"
                                       value="@course.Name"
                                       form="@updateFormId"
                                       required />
                            </td>
                            <td>
                                <input type="number"
                                       class="form-control form-control-sm"
                                       name="fee"
                                       value="@(course.Fee?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))"
                                       min="0"
                                       step="0.01"
                                       placeholder="No fee"
                                       form="@updateFormId" />
                            </td>
                            <td>
                                @if (course.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@(course.CreatedDate.ToShortDateString())</td>
                            <td>
                                <form id="@updateFormId" asp-action="UpdateSection" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@(course.Id)" />
                                    <button type="submit" class="btn btn-sm btn-primary" title="Save">
                                        <i class="bi bi-save"></i>
                                    </button>
                                </form>

                                <form asp-action="ToggleSectionStatus" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@(course.Id)" />
                                    <button type="submit" class="btn btn-sm @(course.IsActive ? "btn-warning" : "btn-success")" title="@(course.IsActive ? "Deactivate" : "Activate")">
                                        <i class="bi @(course.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                    </button>
                                </form>
                                
                                <form asp-action="DeleteSection" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                    <input type="hidden" name="id" value="@(course.Id)" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" />
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No courses created yet. Add your first course above.
        </div>
    }
</section>
