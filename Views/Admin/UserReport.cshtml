@model CandidateAttendanceApp.ViewModels.PaginatedList<CandidateAttendanceApp.Models.Attendance>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "User Attendance Report";
}

<section class="page-title-row reveal">
    <h2 class="mb-2">Attendance Report</h2>
    <p class="text-muted mb-0">Viewing attendance for: <strong>@ViewBag.UserEmail</strong></p>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="panel-card reveal">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0">Attendance Records</h5>
        <a asp-action="UserSummary" class="btn btn-sm btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Users
        </a>
    </div>

    <div class="table-shell">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Work Hours</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Date.ToShortDateString()</td>
                            <td>@(item.CheckIn.HasValue ? item.CheckIn.Value.ToString("hh:mm tt") : "-")</td>
                            <td>@(item.CheckOut.HasValue ? item.CheckOut.Value.ToString("hh:mm tt") : "-")</td>
                            <td>@(item.WorkHours?.ToString("0.00") ?? "-") hrs</td>
                            <td>
                                @if (item.IsLate)
                                {
                                    <span class="badge bg-warning text-dark">Late</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">On-Time</span>
                                }
                            </td>
                            <td>
                                <form asp-controller="Admin" asp-action="ToggleLate" method="post" style="display:inline;">
                                    <input type="hidden" name="attendanceId" value="@item.Id" />
                                    <input type="hidden" name="userId" value="@ViewBag.UserId" />
                                    <button type="submit" class="btn btn-sm @(item.IsLate ? "btn-success" : "btn-warning")">
                                        @if (item.IsLate)
                                        {
                                            <i class="bi bi-check-circle"></i> @:Mark On-Time
                                        }
                                        else
                                        {
                                            <i class="bi bi-exclamation-circle"></i> @:Mark Late
                                        }
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No attendance records found for this user.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        ViewData["CurrentPage"] = Model.CurrentPage;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["TotalRecords"] = Model.TotalRecords;
        ViewData["PaginationAction"] = "UserReport";
        ViewData["PaginationController"] = "Admin";
        ViewData["PaginationRouteValues"] = new Dictionary<string, string?>
        {
            { "userId", ViewBag.UserId as string }
        };
    }
    <partial name="_Pagination" />
</section>
