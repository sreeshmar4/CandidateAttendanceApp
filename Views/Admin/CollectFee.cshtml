@model CandidateAttendanceApp.ViewModels.CollectFeeViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Collect Fee";
}

<section class="page-title-row reveal">
    <h2 class="mb-2">Collect Fee</h2>
    <p class="text-muted mb-0">Enter admission number to load candidate, select a course, and collect the fee.</p>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="panel-card reveal">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h5 class="mb-0">Fee Collection</h5>
        <a asp-action="Fees" class="btn btn-sm btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Fees Management
        </a>
    </div>

    <form asp-action="CollectFee" method="post" id="collectFeeForm">
        <input type="hidden" asp-for="UserId" id="userId" />
        <input type="hidden" asp-for="IsLookupComplete" id="isLookupComplete" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="AdmissionNumber" class="form-label">Admission Number <span class="text-danger">*</span></label>
                <input asp-for="AdmissionNumber" class="form-control" id="admissionNumber" placeholder="Enter admission number" required />
                <span id="admissionError" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="CandidateName" class="form-label">Candidate Name</label>
                <input asp-for="CandidateName" class="form-control" id="candidateName" readonly placeholder="Auto-populated from admission number" />
            </div>

            <div class="col-md-6">
                <label asp-for="CourseId" class="form-label">Course Name <span class="text-danger">*</span></label>
                <select asp-for="CourseId" class="form-select" id="courseId" required>
                    <option value="">-- Select Course --</option>
                    @foreach (var course in Model.Courses)
                    {
                        var fee = course.Fee?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                        <option value="@course.Id" data-course-fee="@fee">@course.Name</option>
                    }
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Amount" class="form-label">Fee Amount <span class="text-danger">*</span></label>
                <input asp-for="Amount" class="form-control" id="amount" min="0.01" step="0.01" placeholder="Enter fee amount" required />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 bg-light-subtle">
                    <div class="text-muted small mb-1">Course Fee</div>
                    <div class="fs-5 fw-semibold" id="courseFeeLabel">--</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 bg-light-subtle">
                    <div class="text-muted small mb-1">Total Collected (incl. Registration)</div>
                    <div class="fs-5 fw-semibold" id="totalCollectedLabel">--</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-3 p-3 bg-light-subtle">
                    <div class="text-muted small mb-1">Pending Dues</div>
                    <div class="fs-5 fw-semibold" id="pendingDuesLabel">--</div>
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="DueDate" class="form-label">Due Date <span class="text-danger">*</span></label>
                <input asp-for="DueDate" type="date" class="form-control" required />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional note"></textarea>
            </div>

            <div class="col-12">
                <div class="d-flex gap-2">
                    <button type="submit" name="submitAction" value="collect" class="btn btn-success px-4">
                        <i class="bi bi-cash-coin"></i> Collect Fee
                    </button>
                    <a asp-action="Fees" class="btn btn-secondary px-4">
                        Cancel
                    </a>
                </div>
            </div>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        const admissionInput = document.getElementById('admissionNumber');
        const candidateNameInput = document.getElementById('candidateName');
        const userIdInput = document.getElementById('userId');
        const isLookupInput = document.getElementById('isLookupComplete');
        const admissionError = document.getElementById('admissionError');
        const courseSelect = document.getElementById('courseId');
        const courseFeeLabel = document.getElementById('courseFeeLabel');
        const totalCollectedLabel = document.getElementById('totalCollectedLabel');
        const pendingDuesLabel = document.getElementById('pendingDuesLabel');

        let currentCourseFee = 0;
        let currentTotalCollected = 0;

        function updateAllLabels() {
            courseFeeLabel.textContent = currentCourseFee > 0 ? 'Rs. ' + currentCourseFee.toFixed(2) : '--';
            totalCollectedLabel.textContent = currentTotalCollected > 0 ? 'Rs. ' + currentTotalCollected.toFixed(2) : 'Rs. 0.00';
            const pending = currentCourseFee - currentTotalCollected;
            pendingDuesLabel.textContent = 'Rs. ' + (pending > 0 ? pending.toFixed(2) : '0.00');
            pendingDuesLabel.className = pending > 0 ? 'fs-5 fw-semibold text-danger' : 'fs-5 fw-semibold text-success';
        }

        function resetAllLabels() {
            currentCourseFee = 0;
            currentTotalCollected = 0;
            courseFeeLabel.textContent = '--';
            totalCollectedLabel.textContent = '--';
            pendingDuesLabel.textContent = '--';
            pendingDuesLabel.className = 'fs-5 fw-semibold';
        }

        let lookupTimer = null;

        admissionInput.addEventListener('input', function () {
            clearTimeout(lookupTimer);
            const val = admissionInput.value.trim();
            if (val.length < 1) { resetCandidate(); return; }
            lookupTimer = setTimeout(() => lookupCandidate(val), 500);
        });

        async function lookupCandidate(admissionNumber) {
            admissionError.textContent = '';
            try {
                const response = await fetch(`@Url.Action("LookupCandidate", "Admin")?admissionNumber=${encodeURIComponent(admissionNumber)}`);
                const data = await response.json();
                if (data.found) {
                    candidateNameInput.value = data.candidateName || '';
                    userIdInput.value = data.userId || '';
                    isLookupInput.value = 'true';
                    currentTotalCollected = parseFloat(data.totalCollected) || 0;

                    if (data.courseId) {
                        courseSelect.value = data.courseId;
                        await fetchCourseFeeInfo();
                    } else {
                        updateAllLabels();
                    }
                } else {
                    resetCandidate();
                    admissionError.textContent = 'No candidate found with this admission number.';
                }
            } catch (e) {
                resetCandidate();
            }
        }

        function resetCandidate() {
            candidateNameInput.value = '';
            userIdInput.value = '';
            isLookupInput.value = 'false';
            resetAllLabels();
        }

        async function fetchCourseFeeInfo() {
            const selected = courseSelect.options[courseSelect.selectedIndex];
            const fee = selected?.dataset?.courseFee;
            currentCourseFee = parseFloat(fee) || 0;

            const userId = userIdInput.value;
            const courseId = courseSelect.value;
            if (userId && courseId) {
                try {
                    const response = await fetch(`@Url.Action("GetCourseFeeInfo", "Admin")?userId=${encodeURIComponent(userId)}&courseId=${encodeURIComponent(courseId)}`);
                    const data = await response.json();
                    if (data) {
                        currentTotalCollected = parseFloat(data.totalCollected) || 0;
                        if (data.courseFee > 0) {
                            currentCourseFee = parseFloat(data.courseFee) || 0;
                        }
                    }
                } catch (e) { }
            }
            updateAllLabels();
        }

        courseSelect.addEventListener('change', fetchCourseFeeInfo);

        if (admissionInput.value.trim().length > 0) {
            lookupCandidate(admissionInput.value.trim());
        }
    </script>
}
