@model CandidateAttendanceApp.ViewModels.PaginatedList<CandidateAttendanceApp.Models.Attendance>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Attendance";
}

<section class="page-title-row reveal">
    <h2 class="mb-2">Attendance</h2>
    <p class="text-muted mb-0">Mark your check-in and check-out, and review daily working hours.</p>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="panel-card reveal">
    <div class="d-flex flex-wrap gap-2 mb-4">
        <form asp-controller="Attendance" asp-action="CheckIn" method="post" style="display:inline;">
            <button type="submit" class="btn btn-success">Check In</button>
        </form>
        <form asp-controller="Attendance" asp-action="CheckOut" method="post" style="display:inline;">
            <button type="submit" class="btn btn-danger">Check Out</button>
        </form>
    </div>

    <div class="table-shell">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Work Hours</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Date.ToShortDateString()</td>
                            <td>@(item.CheckIn.HasValue ? item.CheckIn.Value.ToString("hh:mm tt") : "-")</td>
                            <td>@(item.CheckOut.HasValue ? item.CheckOut.Value.ToString("hh:mm tt") : "-")</td>
                            <td>@(item.WorkHours?.ToString("0.00") ?? "-") hrs</td>
                            <td>
                                @if (item.IsLate)
                                {
                                    <span class="badge bg-warning text-dark">Late</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">On-Time</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No attendance records found.</td>                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        ViewData["CurrentPage"] = Model.CurrentPage;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["TotalRecords"] = Model.TotalRecords;
        ViewData["PaginationAction"] = "Index";
        ViewData["PaginationController"] = "Attendance";
        ViewData["PaginationRouteValues"] = new Dictionary<string, string?>();
    }
    <partial name="_Pagination" />
</section>