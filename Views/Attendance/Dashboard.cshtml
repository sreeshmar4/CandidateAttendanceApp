@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "User Dashboard";
}

<section class="page-title-row reveal">
    <h2 class="mb-2">User Dashboard</h2>
    <p class="text-muted mb-0">Mark your attendance and view your monthly report.</p>
</section>

<div class="row g-4 mt-1">
    <div class="col-12 col-md-6 col-lg-4">
        <section class="panel-card h-100 reveal">
            <h4>Mark Attendance</h4>

            @if (ViewBag.CheckedIn)
            {
                <p class="text-success mt-3 mb-3">You are checked in today.</p>
                <form asp-action="CheckOut" method="post">
                    <button type="submit" class="btn btn-danger">Check Out</button>
                </form>
            }
            else
            {
                <p class="text-warning mt-3 mb-3">You have not checked in today.</p>
                <form asp-action="CheckIn" method="post">
                    <button type="submit" class="btn btn-success">Check In</button>
                </form>
            }
        </section>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <section class="panel-card h-100 reveal">
            <h4>Monthly Attendance %</h4>
            <div class="text-center mt-3">
                <canvas id="attendanceChart" style="max-height: 200px;"></canvas>
            </div>
            <div class="mt-3 text-center">
                <p class="mb-1">
                    <strong class="text-success">@ViewBag.AttendancePercentage%</strong> Present
                </p>
                <p class="text-muted small mb-0">
                    @ViewBag.PresentDays out of @ViewBag.WorkingDays working days
                </p>
            </div>
        </section>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <section class="panel-card h-100 reveal">
            <h4>Monthly Report</h4>
            <p class="text-muted mt-3 mb-3">Review your attendance history and work hours for the month.</p>
            <a asp-action="Monthly" class="btn btn-primary">View Report</a>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const ctx = document.getElementById('attendanceChart').getContext('2d');
        const attendanceChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Present', 'Absent'],
                datasets: [{
                    data: [@ViewBag.AttendancePercentage, @ViewBag.AbsentPercentage],
                    backgroundColor: [
                        'rgba(40, 167, 69, 0.8)',
                        'rgba(220, 53, 69, 0.8)'
                    ],
                    borderColor: [
                        'rgba(40, 167, 69, 1)',
                        'rgba(220, 53, 69, 1)'
                    ],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            font: {
                                size: 12
                            }
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.label + ': ' + context.parsed + '%';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
